  <tbody>
    @foreach($agents as $agent)
      <tr>
        <td>
          <strong>{{ optional($agent->user)->name ?? '—' }}</strong><br>
          <small>{{ optional($agent->user)->email ?? '—' }}</small>
        </td>
        <td>{{ $agent->company }}</td>
        <td>{{ $agent->phone }}</td>
        <td>{{ $agent->license_number }}</td>
        <td>
          <span class="badge {{ $agent->verification_status == 'pending' ? 'bg-secondary' : ($agent->verification_status=='approved' ? 'bg-success' : 'bg-danger') }}">
            {{ ucfirst($agent->verification_status) }}
          </span>
        </td>
        <td>
          @if($agent->blacklist)
            <span class="badge bg-danger">Yes</span>
          @else
            <span class="badge bg-success">No</span>
          @endif
        </td>
        <td>{{ $agent->created_at ? $agent->created_at->format('Y-m-d') : '-' }}</td>
        <td><a href="{{ route('admin.agents.show', $agent) }}" class="btn btn-sm btn-outline-primary">View</a></td>
      </tr>
